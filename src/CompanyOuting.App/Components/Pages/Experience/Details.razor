@page "/experience/{Slug}"

@inject NavigationManager Navigation

<PageTitle>@(_experience?.Title ?? "Experience") - Company Outing</PageTitle>

@if (_experience is null)
{
    <div class="experience-not-found">
        <h1>Experience not found</h1>
        <a href="/marketplace">Back to marketplace</a>
    </div>
}
else
{
    <div class="experience-detail-page">
        <div class="experience-detail-shell">
            <div class="experience-breadcrumbs">
                <span>Home</span>
                <span>/</span>
                <span>@_experience.Country</span>
                <span>/</span>
                <strong>@_experience.Title</strong>
            </div>

            <a href="/marketplace" class="experience-back-link">&larr; Back to marketplace</a>

            <div class="experience-detail-grid">
                <section class="experience-main">
                    <img src="@_experience.HeroImage" alt="@_experience.Title" class="experience-hero-image" />

                    <div class="experience-thumb-row">
                        @foreach (var image in _experience.GalleryImages)
                        {
                            <img src="@image" alt="@_experience.Title" class="experience-thumb" />
                        }
                    </div>

                    <div class="experience-provider-row">
                        <div class="experience-provider-meta">
                            <img src="@_experience.ProviderAvatar" alt="@_experience.ProviderName" class="experience-provider-avatar" />
                            <div>
                                <span class="experience-provider-label">Offered by</span>
                                <strong>@_experience.ProviderName</strong>
                            </div>
                        </div>
                        <div class="experience-provider-badge">Verified Provider</div>
                    </div>

                    <h1 class="experience-title">@_experience.Title</h1>

                    <div class="experience-meta-row">
                        <span>@_experience.Location</span>
                        <span>@_experience.People people</span>
                        <span>@_experience.Duration</span>
                    </div>

                    <div class="experience-rating-chip">★ @_experience.Rating <span>(@_experience.Reviews reviews)</span></div>

                    <div class="experience-tag-row">
                        @foreach (var tag in _experience.Tags)
                        {
                            <span class="experience-tag">@tag</span>
                        }
                    </div>

                    <section class="experience-section">
                        <h2>About This Experience</h2>
                        <p>@_experience.About</p>
                        <small>@_experience.TeamFit</small>
                    </section>

                    <section class="experience-section">
                        <h2>Itinerary</h2>
                        <ul class="experience-list">
                            @foreach (var item in _experience.Itinerary)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </section>

                    <section class="experience-section">
                        <h2>What's Included</h2>
                        <div class="experience-include-grid">
                            @foreach (var item in _experience.Included)
                            {
                                <div class="experience-include-item">@item</div>
                            }
                        </div>
                    </section>

                    <section class="experience-section">
                        <h2>Similar Experiences You Might Like</h2>
                        <div class="experience-similar-grid">
                            @foreach (var similar in _experience.Similar)
                            {
                                <article class="experience-similar-card">
                                    <img src="@similar.Image" alt="@similar.Title" />
                                    <div class="experience-similar-body">
                                        <div class="experience-similar-rating">★ @similar.Rating</div>
                                        <h3>@similar.Title</h3>
                                        <p>@similar.Location</p>
                                        <div class="experience-similar-price">From $@similar.Price <span>/person</span></div>
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                </section>

                <aside class="experience-booking-card">
                    <div class="experience-price-head">
                        <span>Starting From</span>
                        <div>$@_experience.Price <small>/person</small></div>
                    </div>

                    <div class="experience-booking-field">
                        <label>Group Size</label>
                        <div class="experience-stepper">
                            <button type="button" @onclick="DecreaseGuests">-</button>
                            <input type="number" @bind="_guestCount" min="@_experience.MinGuests" max="@_experience.MaxGuests" />
                            <button type="button" @onclick="IncreaseGuests">+</button>
                        </div>
                        <small>Min: @_experience.MinGuests · Max: @_experience.MaxGuests</small>
                    </div>

                    <div class="experience-booking-field">
                        <label>Preferred Date</label>
                        <InputDate @bind-Value="_preferredDate" class="experience-date-input" />
                    </div>

                    <div class="experience-total-row">
                        <span>Subtotal (@_guestCount people)</span>
                        <strong>$@(_guestCount * _experience.Price)</strong>
                    </div>

                    <div class="experience-total-row experience-total-main">
                        <span>Total</span>
                        <strong>$@(_guestCount * _experience.Price)</strong>
                    </div>

                    <button class="experience-primary-btn">Request Booking</button>
                    <button class="experience-secondary-btn">Contact Provider</button>

                    <ul class="experience-policy-list">
                        <li>Free cancellation up to 30 days</li>
                        <li>Invoice payment available for businesses</li>
                    </ul>
                </aside>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private ExperienceDetail? _experience;
    private int _guestCount = 50;
    private DateTime? _preferredDate;

    protected override void OnParametersSet()
    {
        _experience = Experiences.FirstOrDefault(x => x.Slug.Equals(Slug, StringComparison.OrdinalIgnoreCase));

        if (_experience is not null)
        {
            _guestCount = Math.Clamp(50, _experience.MinGuests, _experience.MaxGuests);
        }
    }

    private void IncreaseGuests()
    {
        if (_experience is null) return;
        _guestCount = Math.Min(_guestCount + 1, _experience.MaxGuests);
    }

    private void DecreaseGuests()
    {
        if (_experience is null) return;
        _guestCount = Math.Max(_guestCount - 1, _experience.MinGuests);
    }

    private static readonly List<ExperienceDetail> Experiences =
