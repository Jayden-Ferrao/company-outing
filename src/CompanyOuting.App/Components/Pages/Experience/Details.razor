    );

    private sealed record SimilarExperience(string Title, string Location, decimal Rating, int Price, string Image);
}

<style>
    .experience-detail-page {
        padding: 32px 24px 80px;
        background: #f8fafc;
    }

    .experience-detail-shell {
        max-width: 1180px;
        margin: 0 auto;
    }

    .experience-breadcrumbs,
    .experience-back-link {
        color: #64748b;
        font-size: 0.85rem;
    }

    .experience-breadcrumbs {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
    }

    .experience-back-link {
        display: inline-block;
        margin-bottom: 22px;
        text-decoration: none;
    }

    .experience-detail-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 310px;
        gap: 28px;
        align-items: start;
    }

    .experience-main,
    .experience-booking-card {
        background: #fff;
        border: 1px solid #dbe4ee;
    }

    .experience-main {
        padding: 20px;
    }

    .experience-hero-image {
        width: 100%;
        height: 420px;
        object-fit: cover;
        display: block;
    }

    .experience-thumb-row {
        display: flex;
        gap: 10px;
        margin: 12px 0 14px;
    }

    .experience-thumb {
        width: 110px;
        height: 72px;
        object-fit: cover;
        border: 1px solid #dbe4ee;
    }

    .experience-provider-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .experience-provider-meta {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .experience-provider-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        object-fit: cover;
    }

    .experience-provider-label,
    .experience-provider-badge {
        color: #64748b;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-weight: 800;
    }

    .experience-title {
        margin: 0 0 10px;
        color: #0f172a;
        font-size: 3rem;
        line-height: 1.05;
        letter-spacing: -1.5px;
    }

    .experience-meta-row,
    .experience-tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .experience-meta-row {
        margin-bottom: 14px;
        color: #64748b;
        font-size: 0.95rem;
        font-weight: 600;
    }

    .experience-rating-chip {
        display: inline-flex;
        gap: 6px;
        padding: 10px 12px;
        border: 1px solid #dbe4ee;
        color: #0f172a;
        font-size: 0.95rem;
        font-weight: 800;
    }

    .experience-rating-chip span {
        color: #64748b;
        font-weight: 600;
    }

    .experience-tag-row {
        margin: 16px 0 22px;
    }

    .experience-tag {
        padding: 7px 10px;
        border: 1px solid #dbe4ee;
        color: #64748b;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .experience-section {
        padding: 24px 0;
        border-top: 1px solid #dbe4ee;
    }

    .experience-section h2 {
        margin: 0 0 14px;
        color: #172033;
        font-size: 1.8rem;
        font-weight: 800;
    }

    .experience-section p,
    .experience-section small,
    .experience-list li,
    .experience-include-item {
        color: #52627e;
        font-size: 1rem;
        line-height: 1.7;
    }

    .experience-list {
        margin: 0;
        padding-left: 18px;
    }

    .experience-include-grid,
    .experience-similar-grid {
        display: grid;
        gap: 18px;
    }

    .experience-include-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .experience-similar-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .experience-similar-card {
        border: 1px solid #dbe4ee;
        background: #fff;
        overflow: hidden;
    }

    .experience-similar-card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
    }

    .experience-similar-body {
        padding: 14px;
    }

    .experience-similar-rating {
        display: inline-block;
        margin-bottom: 12px;
        padding: 6px 10px;
        background: #fff;
        border: 1px solid #dbe4ee;
        font-size: 0.82rem;
        font-weight: 800;
    }

    .experience-similar-body h3 {
        margin: 0 0 8px;
        color: #172033;
        font-size: 1rem;
        font-weight: 800;
    }

    .experience-similar-body p {
        margin: 0 0 10px;
        color: #64748b;
        font-size: 0.88rem;
    }

    .experience-similar-price {
        color: #0f172a;
        font-size: 1.3rem;
        font-weight: 900;
    }

    .experience-similar-price span {
        color: #64748b;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .experience-booking-card {
        position: sticky;
        top: 120px;
        padding: 20px;
    }

    .experience-price-head {
        padding-bottom: 18px;
        border-bottom: 1px solid #dbe4ee;
    }

    .experience-price-head span,
    .experience-booking-field label {
        display: block;
        margin-bottom: 8px;
        color: #64748b;
        font-size: 0.75rem;
        font-weight: 900;
        letter-spacing: 0.8px;
        text-transform: uppercase;
    }

    .experience-price-head div {
        color: #0f172a;
        font-size: 3rem;
        font-weight: 900;
        line-height: 1;
    }

    .experience-price-head small {
        color: #64748b;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .experience-booking-field {
        margin-top: 20px;
    }

    .experience-stepper {
        display: grid;
        grid-template-columns: 36px 1fr 36px;
        gap: 10px;
    }

    .experience-stepper button,
    .experience-stepper input,
    .experience-date-input,
    .experience-primary-btn,
    .experience-secondary-btn {
        min-height: 44px;
        font-family: inherit;
        font-size: 0.95rem;
    }

    .experience-stepper button {
        border: 1px solid #dbe4ee;
        background: #fff;
        color: #0f172a;
        cursor: pointer;
    }

    .experience-stepper input,
    .experience-date-input {
        width: 100%;
        padding: 0 12px;
        border: 1px solid #dbe4ee;
    }

    .experience-booking-field small {
        display: block;
        margin-top: 8px;
        color: #64748b;
        font-size: 0.78rem;
    }

    .experience-total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 18px;
        color: #64748b;
        font-size: 0.92rem;
    }

    .experience-total-main {
        padding: 14px 0 18px;
        border-bottom: 1px solid #dbe4ee;
        color: #0f172a;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .experience-primary-btn,
    .experience-secondary-btn {
        width: 100%;
        margin-top: 14px;
        text-transform: uppercase;
        font-weight: 900;
        letter-spacing: 0.8px;
        cursor: pointer;
    }

    .experience-primary-btn {
        border: none;
        background: #0b1739;
        color: #fff;
    }

    .experience-secondary-btn {
        border: 1px solid #0b1739;
        background: #fff;
        color: #0b1739;
    }

    .experience-policy-list {
        margin: 18px 0 0;
        padding-left: 18px;
        color: #64748b;
        font-size: 0.84rem;
        line-height: 1.8;
    }

    .experience-not-found {
        max-width: 760px;
        margin: 80px auto;
        padding: 32px;
        text-align: center;
    }

    @@media (max-width: 960px) {
        .experience-detail-grid {
            grid-template-columns: 1fr;
        }

        .experience-booking-card {
            position: static;
        }

        .experience-similar-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
