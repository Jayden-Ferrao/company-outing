                new("Progressive Dinner Party at Supper Club Stavanger", "Stavanger", 4.9m, 1250, "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?q=80&w=400&auto=format&fit=crop")
            ]
        ),
        new(
