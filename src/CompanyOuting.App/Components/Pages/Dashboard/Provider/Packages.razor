@page "/dashboard/packages"
@page "/provider/packages"
@layout CompanyOuting.App.Components.Layout.ProviderLayout

@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject UserSessionService Session

<PageTitle>My Packages - Company Outing</PageTitle>

@if (_isReady)
{
    <div class="provider-packages-page">
        <div class="provider-packages-shell">
            <aside class="provider-sidebar">
                <nav class="provider-sidebar-nav">
                    @foreach (var item in _navItems)
                    {
                        <a href="@item.Href" class="provider-nav-link @(item.IsActive ? "is-active" : string.Empty)">
                            <span class="provider-nav-icon">@item.Icon</span>
                            <span>@item.Label</span>
                        </a>
                    }
                </nav>
            </aside>

            <section class="provider-main">
                <header class="provider-hero">
                    <div>
                        <h1>My Packages</h1>
                        <p>Manage your listed experiences</p>
                    </div>
                </header>

                <section class="provider-panel">
                    <div class="provider-panel-head provider-panel-head-start">
                        <h2>All Packages (2)</h2>
                    </div>

                    <div class="provider-package-list">
                        @foreach (var package in _packages)
                        {
                            <article class="provider-package-card">
                                <img src="@package.Image" alt="@package.Title" />

                                <div class="provider-package-content">
                                    <h3>@package.Title</h3>
                                    <p>@package.Description</p>
                                    <div class="provider-package-stats">
                                        <span>@package.Views views</span>
                                        <span>@package.Rating (@package.Reviews)</span>
                                        <span>$@package.Price/person</span>
                                    </div>
                                </div>

                                <div class="provider-package-actions">
                                    <span class="provider-package-status">APPROVED</span>
                                    <div class="provider-package-buttons">
                                        <a href="/marketplace" class="provider-action-btn">
                                            <span class="provider-action-icon">◌</span>
                                            <span>Preview</span>
                                        </a>
                                        <a href="/provider/create" class="provider-action-btn">
                                            <span class="provider-action-icon">✎</span>
                                            <span>Edit</span>
                                        </a>
                                        <button type="button" class="provider-action-btn provider-action-btn-danger">
                                            <span class="provider-action-icon">⌦</span>
                                        </button>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </section>
            </section>
        </div>
    </div>
}

@code {
    private bool _isReady;

    private readonly List<DashboardNavItem> _navItems =
    [
        new("⌘", "Dashboard", "/dashboard", false),
        new("◫", "My Packages", "/dashboard/packages", true),
        new("☷", "Bookings", "/dashboard/bookings", false),
        new("⚙", "Settings", "/dashboard/settings", false)
    ];

    private readonly List<PackageCard> _packages =
    [
        new("Alpine Team Building Adventure", "Swiss Alps team retreat with outdoor challenges and workshops", "3421", "4.8", "127", "850", "https://images.unsplash.com/photo-1519681393784-d120267933ba?q=80&w=600&auto=format&fit=crop"),
        new("Wilderness Survival Challenge", "Survival training in Canadian Rockies", "2341", "4.6", "93", "1200", "https://images.unsplash.com/photo-1506744038136-46273834b3fb?q=80&w=600&auto=format&fit=crop")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.EnsureLoadedAsync(JsRuntime);

        if (!Session.IsProvider)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        await InvokeAsync(StateHasChanged);
    }

    private sealed record DashboardNavItem(string Icon, string Label, string Href, bool IsActive);
    private sealed record PackageCard(string Title, string Description, string Views, string Rating, string Reviews, string Price, string Image);
}

<style>
    .provider-packages-page {
        background: #eef2f6;
    }

    .provider-packages-shell {
        display: grid;
        grid-template-columns: 280px minmax(0, 1fr);
        min-height: calc(100vh - 100px);
    }

    .provider-sidebar {
        padding: 28px 0 32px;
        background: #f9fbfc;
        border-right: 1px solid #d9e1ea;
    }

    .provider-sidebar-nav {
        display: flex;
        flex-direction: column;
        padding-top: 24px;
    }

    .provider-nav-link {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 18px 24px;
        color: #5b6b84;
        text-decoration: none;
        font-size: 0.96rem;
        font-weight: 800;
        letter-spacing: 0.6px;
    }

    .provider-nav-link.is-active {
        background: #eef2f7;
        color: #0f172a;
    }

    .provider-nav-icon {
        width: 22px;
        text-align: center;
        color: #64748b;
    }

    .provider-main {
        padding-bottom: 48px;
    }

    .provider-toolbar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        min-height: 82px;
        padding: 18px 28px;
        background: #ffffff;
        border-bottom: 1px solid #d9e1ea;
    }

    .provider-toolbar-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .provider-toolbar-primary,
    .provider-toolbar-secondary,
    .provider-action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 800;
    }

    .provider-toolbar-primary {
        height: 44px;
        padding: 0 18px;
        background: #0b1739;
        color: #fff;
        border-radius: 2px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-size: 0.8rem;
    }

    .provider-toolbar-secondary,
    .provider-action-btn {
        height: 44px;
        padding: 0 18px;
        border: 1px solid #d0d8e4;
        color: #6d4f32;
        border-radius: 2px;
        background: #fff;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-size: 0.78rem;
        cursor: pointer;
        font-family: inherit;
    }

    .provider-toolbar-signout {
        color: #24314f;
    }

    .provider-hero,
    .provider-panel {
        margin: 24px 28px 0;
        padding: 26px 24px;
        background: #ffffff;
        border: 1px solid #d9e1ea;
    }

    .provider-hero h1,
    .provider-panel h2 {
        margin: 0;
        color: #0f172a;
    }

    .provider-hero h1 {
        font-size: clamp(2.6rem, 5vw, 3.6rem);
        font-weight: 900;
        letter-spacing: -1.5px;
    }

    .provider-hero p {
        margin: 8px 0 0;
        color: #607089;
        font-size: 1rem;
    }

    .provider-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
    }

    .provider-panel-head-start {
        justify-content: flex-start;
    }

    .provider-panel h2 {
        font-size: 1.6rem;
        font-weight: 800;
        letter-spacing: -0.6px;
    }

    .provider-package-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .provider-package-card {
        display: grid;
        grid-template-columns: 114px minmax(0, 1fr) auto;
        gap: 18px;
        align-items: center;
        padding: 18px 16px;
        border: 1px solid #d9e1ea;
        background: #fcfdff;
    }

    .provider-package-card img {
        width: 96px;
        height: 96px;
        object-fit: cover;
    }

    .provider-package-content h3 {
        margin: 0;
        color: #172033;
        font-weight: 800;
        font-size: 1.1rem;
    }

    .provider-package-content p {
        margin: 6px 0 10px;
        color: #607089;
        font-size: 0.95rem;
    }

    .provider-package-stats {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        color: #607089;
        font-weight: 600;
        font-size: 0.92rem;
    }

    .provider-package-actions {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .provider-package-status {
        padding: 8px 14px;
        background: #e8f7ef;
        color: #198754;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.8px;
    }

    .provider-package-buttons {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .provider-action-btn {
        gap: 8px;
        height: 36px;
        padding: 0 12px;
    }

    .provider-action-btn-danger {
        min-width: 36px;
        padding: 0;
        color: #ef4444;
        border-color: #f5c2c7;
    }

    .provider-action-icon {
        font-size: 0.8rem;
        line-height: 1;
    }

    @@media (max-width: 1100px) {
        .provider-package-card {
            grid-template-columns: 1fr;
            align-items: flex-start;
        }

        .provider-package-actions {
            flex-wrap: wrap;
        }
    }

    @@media (max-width: 960px) {
        .provider-packages-shell {
            grid-template-columns: 1fr;
        }

        .provider-sidebar {
            border-right: none;
            border-bottom: 1px solid #d9e1ea;
        }
    }

    @@media (max-width: 720px) {
        .provider-toolbar,
        .provider-hero,
        .provider-panel {
            margin-left: 16px;
            margin-right: 16px;
            padding: 20px;
        }

        .provider-toolbar-actions,
        .provider-package-buttons {
            flex-wrap: wrap;
        }
    }
</style>

