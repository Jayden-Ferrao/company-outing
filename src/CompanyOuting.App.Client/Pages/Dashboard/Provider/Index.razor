@page "/dashboard"
@page "/dashboard/provider"
@page "/provider/dashboard"
@layout CompanyOuting.App.Client.Components.Layout.ProviderLayout
@rendermode InteractiveServer

@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject UserSessionService Session

<PageTitle>Provider Dashboard - Company Outing</PageTitle>

@if (_isReady)
{
    <div class="provider-dashboard-page">
        <div class="provider-dashboard-shell">
            <aside class="provider-sidebar">
                <nav class="provider-sidebar-nav">
                    @foreach (var item in _navItems)
                    {
                        <a href="@item.Href" class="provider-nav-link @(item.IsActive ? "is-active" : string.Empty)">
                            <span class="provider-nav-icon">@item.Icon</span>
                            <span>@item.Label</span>
                        </a>
                    }
                </nav>
            </aside>

            <section class="provider-main">
                <header class="provider-hero">
                    <div>
                        <h1>Dashboard</h1>
                        <p>Welcome back! Here's an overview of your business.</p>
                    </div>
                </header>

                <section class="provider-stats-grid">
                    @foreach (var stat in _statCards)
                    {
                        <article class="provider-stat-card">
                            <div class="provider-stat-meta">
                                <span>@stat.Label</span>
                                <span class="provider-stat-icon">@stat.Icon</span>
                            </div>
                            <h2>@stat.Value</h2>
                            <p>@stat.Caption</p>
                        </article>
                    }
                </section>

                <section class="provider-panel">
                    <div class="provider-panel-head">
                        <h2>Recent Booking Requests</h2>
                        <a href="/dashboard/bookings" class="provider-panel-action">View All</a>
                    </div>

                    <article class="provider-booking-card">
                        <div class="provider-booking-main">
                            <h3>Alpine Team Building Adventure</h3>
                            <p>TechCorp International</p>
                        </div>
                        <div class="provider-booking-meta">
                            <div>
                                <span class="provider-booking-label">GROUP SIZE</span>
                                <strong>45 people</strong>
                            </div>
                            <div>
                                <span class="provider-booking-label">DATE</span>
                                <strong>2026-06-15</strong>
                            </div>
                            <div>
                                <span class="provider-booking-label">VALUE</span>
                                <strong>$38,250</strong>
                            </div>
                        </div>
                        <div class="provider-booking-actions">
                            <span class="provider-booking-status">PENDING</span>
                            <a href="/dashboard/bookings" class="provider-respond-btn">Respond</a>
                        </div>
                    </article>
                </section>

                <section class="provider-panel">
                    <div class="provider-panel-head">
                        <h2>Top Performing Packages</h2>
                        <a href="/dashboard/packages" class="provider-panel-action">Manage All</a>
                    </div>

                    <div class="provider-package-list">
                        @foreach (var package in _packages)
                        {
                            <article class="provider-package-card">
                                <img src="@package.Image" alt="@package.Title" />
                                <div class="provider-package-content">
                                    <h3>@package.Title</h3>
                                    <div class="provider-package-stats">
                                        <span>@package.Views views</span>
                                        <span>@package.Rating (@package.Reviews)</span>
                                        <span>$@package.Price/person</span>
                                    </div>
                                </div>
                                <a href="/dashboard/packages" class="provider-edit-btn">Edit</a>
                            </article>
                        }
                    </div>
                </section>
            </section>
        </div>
    </div>
}

@code {
    private bool _isReady;

    private readonly List<DashboardNavItem> _navItems =
    [
        new("⌘", "Dashboard", "/dashboard", true),
        new("◫", "My Packages", "/dashboard/packages", false),
        new("☷", "Bookings", "/dashboard/bookings", false),
        new("⚙", "Settings", "/dashboard/settings", false)
    ];

    private readonly List<StatCard> _statCards =
    [
        new("ACTIVE PACKAGES", "2", "0 pending approval", "◫"),
        new("PENDING BOOKINGS", "1", "Requires your response", "☷"),
        new("TOTAL VIEWS", "5,762", "Across all packages", "◌"),
        new("AVERAGE RATING", "4.7", "From customer reviews", "☆")
    ];

    private readonly List<PackageCard> _packages =
    [
        new("Alpine Team Building Adventure", "3421", "4.8", "127", "850", "https://images.unsplash.com/photo-1519681393784-d120267933ba?q=80&w=600&auto=format&fit=crop"),
        new("Wilderness Survival Challenge", "2341", "4.6", "93", "1200", "https://images.unsplash.com/photo-1506744038136-46273834b3fb?q=80&w=600&auto=format&fit=crop")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.EnsureLoadedAsync(JsRuntime);

        if (!Session.IsProvider)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _isReady = true;
        await InvokeAsync(StateHasChanged);
    }

    private sealed record DashboardNavItem(string Icon, string Label, string Href, bool IsActive);
    private sealed record StatCard(string Label, string Value, string Caption, string Icon);
    private sealed record PackageCard(string Title, string Views, string Rating, string Reviews, string Price, string Image);
}

<style>
    .provider-dashboard-page {
        background: #eef2f6;
    }

    .provider-dashboard-shell {
        display: grid;
        grid-template-columns: 280px minmax(0, 1fr);
        min-height: calc(100vh - 100px);
    }

    .provider-sidebar {
        padding: 28px 0 32px;
        background: #f9fbfc;
        border-right: 1px solid #d9e1ea;
    }

    .provider-sidebar-nav {
        display: flex;
        flex-direction: column;
        padding-top: 24px;
    }

    .provider-nav-link {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 18px 24px;
        color: #5b6b84;
        text-decoration: none;
        font-size: 0.96rem;
        font-weight: 800;
        letter-spacing: 0.6px;
    }

    .provider-nav-link.is-active {
        background: #eef2f7;
        color: #0f172a;
    }

    .provider-nav-icon {
        width: 22px;
        text-align: center;
        color: #64748b;
    }

    .provider-main {
        padding: 0 0 48px;
    }

    .provider-toolbar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        min-height: 82px;
        padding: 18px 28px;
        background: #ffffff;
        border-bottom: 1px solid #d9e1ea;
    }

    .provider-toolbar-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .provider-toolbar-primary,
    .provider-toolbar-secondary,
    .provider-panel-action,
    .provider-respond-btn,
    .provider-edit-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 800;
    }

    .provider-toolbar-primary {
        height: 52px;
        padding: 0 22px;
        background: #0b1739;
        color: #fff;
        border-radius: 2px;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .provider-toolbar-secondary,
    .provider-panel-action,
    .provider-edit-btn {
        height: 44px;
        padding: 0 18px;
        border: 1px solid #24314f;
        color: #24314f;
        border-radius: 4px;
        background: #fff;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-size: 0.8rem;
    }

    .provider-toolbar-signout {
        cursor: pointer;
        font-family: inherit;
    }

    .provider-hero,
    .provider-panel {
        margin: 24px 28px 0;
        padding: 30px 38px;
        background: #ffffff;
        border: 1px solid #d9e1ea;
        border-radius: 0 0 24px 0;
    }

    .provider-hero h1,
    .provider-panel h2 {
        margin: 0;
        color: #0f172a;
    }

    .provider-hero h1 {
        font-size: clamp(2.8rem, 5vw, 4rem);
        font-weight: 900;
        letter-spacing: -2px;
    }

    .provider-hero p {
        margin: 12px 0 0;
        color: #607089;
        font-size: 1.1rem;
    }

    .provider-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 24px;
        margin: 24px 28px 0;
    }

    .provider-stat-card {
        padding: 28px;
        background: #ffffff;
        border: 1px solid #d9e1ea;
    }

    .provider-stat-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #70819a;
        font-size: 0.86rem;
        font-weight: 800;
        letter-spacing: 1px;
    }

    .provider-stat-card h2 {
        margin: 20px 0 10px;
        font-size: clamp(2.2rem, 4vw, 3.3rem);
        font-weight: 900;
        color: #0f172a;
        letter-spacing: -1px;
    }

    .provider-stat-card p {
        margin: 0;
        color: #607089;
    }

    .provider-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 28px;
    }

    .provider-panel h2 {
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        font-weight: 900;
        letter-spacing: -1px;
    }

    .provider-booking-card {
        display: grid;
        grid-template-columns: minmax(220px, 1.6fr) minmax(320px, 1fr) auto;
        gap: 28px;
        padding: 28px;
        border: 1px solid #d9e1ea;
        background: #fcfdff;
    }

    .provider-booking-main h3,
    .provider-package-content h3 {
        margin: 0;
        color: #172033;
        font-weight: 800;
    }

    .provider-booking-main p {
        margin: 8px 0 0;
        color: #607089;
        font-size: 1rem;
    }

    .provider-booking-meta {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        align-content: end;
    }

    .provider-booking-label {
        display: block;
        margin-bottom: 6px;
        color: #70819a;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 1px;
    }

    .provider-booking-meta strong {
        color: #172033;
        font-size: 1rem;
    }

    .provider-booking-actions {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        gap: 12px;
        white-space: nowrap;
    }

    .provider-booking-status {
        padding: 10px 14px;
        background: #f8edd2;
        color: #a16207;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.8px;
    }

    .provider-respond-btn {
        min-width: 126px;
        height: 46px;
        padding: 0 18px;
        background: #0b1739;
        color: #fff;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .provider-package-list {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .provider-package-card {
        display: grid;
        grid-template-columns: 112px minmax(0, 1fr) auto;
        gap: 26px;
        align-items: center;
        padding: 26px 28px;
        border: 1px solid #d9e1ea;
        background: #fcfdff;
    }

    .provider-package-card img {
        width: 112px;
        height: 92px;
        object-fit: cover;
        border-radius: 4px;
    }

    .provider-package-stats {
        display: flex;
        gap: 18px;
        margin-top: 10px;
        flex-wrap: wrap;
        color: #607089;
        font-weight: 600;
    }

    @@media (max-width: 1200px) {
        .provider-stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .provider-booking-card {
            grid-template-columns: 1fr;
        }

        .provider-booking-actions {
            align-items: flex-start;
            flex-wrap: wrap;
        }
    }

    @@media (max-width: 960px) {
        .provider-dashboard-shell {
            grid-template-columns: 1fr;
        }

        .provider-sidebar {
            border-right: none;
            border-bottom: 1px solid #d9e1ea;
        }
    }

    @@media (max-width: 720px) {
        .provider-toolbar,
        .provider-hero,
        .provider-panel {
            margin-left: 16px;
            margin-right: 16px;
            padding: 24px;
        }

        .provider-stats-grid {
            grid-template-columns: 1fr;
            margin-left: 16px;
            margin-right: 16px;
        }

        .provider-package-card {
            grid-template-columns: 1fr;
        }

        .provider-booking-meta {
            grid-template-columns: 1fr;
        }
    }
</style>
