@page "/login"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations

@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime
@inject UserSessionService Session

<PageTitle>Provider Login - Company Outing</PageTitle>

<div class="provider-login-page">
    <div class="provider-login-shell">
        <p class="provider-login-eyebrow">PROVIDER LOGIN</p>
        <h1 class="provider-login-title">Welcome Back</h1>
        <p class="provider-login-subtitle">Sign in to manage your packages and bookings</p>

        <EditForm Model="_model" OnValidSubmit="HandleLogin" class="provider-login-card">
            <DataAnnotationsValidator />
            <ValidationSummary class="provider-login-validation" />

            <label class="provider-login-label" for="email">EMAIL</label>
            <InputText id="email" @bind-Value="_model.Email" class="provider-login-input" placeholder="your@email.com" />

            <div class="provider-login-password-row">
                <label class="provider-login-label" for="password">PASSWORD</label>
                <a class="provider-login-link" href="/login">Forgot password?</a>
            </div>
            <InputText id="password" @bind-Value="_model.Password" type="password" class="provider-login-input" placeholder="Enter your password" />

            <button type="submit" class="provider-login-submit">SIGN IN</button>

            <p class="provider-login-signup">Don't have an account? <a href="/signup">Sign up here</a></p>
        </EditForm>

        <a class="provider-login-back" href="/marketplace">&larr; Back to marketplace</a>
    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private bool _checkedExistingSession;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _checkedExistingSession)
        {
            return;
        }

        await Session.EnsureLoadedAsync(JsRuntime);
        _checkedExistingSession = true;

        if (Session.IsProvider)
        {
            Navigation.NavigateTo("/dashboard");
        }
    }

    private async Task HandleLogin()
    {
        await Session.SignInAsProviderAsync(_model.Email, JsRuntime);
        Navigation.NavigateTo("/dashboard");
    }

    private sealed class LoginModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required, MinLength(6)]
        public string Password { get; set; } = string.Empty;
    }
}

<style>
    .provider-login-page {
        min-height: calc(100vh - 100px);
        padding: 180px 24px 120px;
        background: #f7f7f4;
    }

    .provider-login-shell {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
        color: #14213d;
    }

    .provider-login-eyebrow {
        margin: 0 0 20px;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: #64748b;
    }

    .provider-login-title {
        margin: 0;
        font-size: clamp(3rem, 6vw, 4.5rem);
        font-weight: 900;
        letter-spacing: -2px;
        color: #0f172a;
    }

    .provider-login-subtitle {
        margin: 18px 0 44px;
        font-size: 1.05rem;
        color: #52627d;
    }

    .provider-login-card {
        max-width: 710px;
        margin: 0 auto;
        padding: 46px 50px 38px;
        text-align: left;
        background: #ffffff;
        border: 1px solid #d9e1ea;
    }

    .provider-login-validation {
        margin-bottom: 18px;
        color: #b91c1c;
        font-size: 0.9rem;
    }

    .provider-login-label {
        display: block;
        margin-bottom: 14px;
        font-size: 0.92rem;
        font-weight: 900;
        color: #172033;
        letter-spacing: 1px;
    }

    .provider-login-password-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 34px;
    }

    .provider-login-link {
        color: #55657f;
        font-size: 0.9rem;
        text-decoration: none;
    }

    .provider-login-input {
        width: 100%;
        height: 70px;
        padding: 0 18px;
        border: 1px solid #cbd5e1;
        border-radius: 2px;
        font-size: 1rem;
        color: #9a6b45;
        background: #ffffff;
        outline: none;
    }

    .provider-login-input:focus {
        border-color: #0f172a;
    }

    .provider-login-submit {
        width: 100%;
        height: 74px;
        margin-top: 40px;
        border: none;
        border-radius: 2px;
        background: #0b1739;
        color: #ffffff;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 1px;
        cursor: pointer;
    }

    .provider-login-signup {
        margin: 34px 0 0;
        text-align: center;
        color: #52627d;
        font-size: 0.95rem;
    }

    .provider-login-signup a,
    .provider-login-back {
        color: #14213d;
        font-weight: 800;
        text-decoration: none;
    }

    .provider-login-back {
        display: inline-block;
        margin-top: 40px;
        font-size: 0.95rem;
        color: #55657f;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .provider-login-page {
            padding-top: 140px;
        }

        .provider-login-card {
            padding: 32px 24px;
        }

        .provider-login-password-row {
            align-items: flex-start;
            flex-direction: column;
            gap: 8px;
        }
    }
</style>
