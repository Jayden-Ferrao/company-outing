@page "/logout"
@rendermode InteractiveServer

@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject UserSessionService Session

<PageTitle>Logging Out - Company Outing</PageTitle>

<div class="logout-page">
    <div class="logout-card">
        <h1>Logging Out</h1>
        <p>Signing you out and returning to the marketplace...</p>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Session.SignOutAsync(JsRuntime);
        Navigation.NavigateTo("/marketplace", forceLoad: true);
    }
}

<style>
    .logout-page {
        min-height: 60vh;
        display: grid;
        place-items: center;
        padding: 40px 20px;
    }

    .logout-card {
        padding: 28px 32px;
        border: 1px solid #d9e1ea;
        background: #ffffff;
        text-align: center;
    }

    .logout-card h1 {
        margin: 0 0 10px;
        color: #0f172a;
        font-size: 2rem;
        font-weight: 800;
    }

    .logout-card p {
        margin: 0;
        color: #64748b;
    }
</style>
