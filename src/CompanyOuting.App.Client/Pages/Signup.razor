@page "/signup"
@page "/provider/signup"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations

@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Become a Provider - Company Outing</PageTitle>

<div class="provider-signup-page">
    <div class="provider-signup-shell">
        <div class="provider-signup-logo">
            <div class="provider-signup-logo-top">
                <span class="provider-signup-line"></span>
                <span class="provider-signup-company">COMPANY</span>
                <span class="provider-signup-line"></span>
            </div>
            <div class="provider-signup-logo-bottom">
                <span class="provider-signup-outing">OUTING</span>
                <span class="provider-signup-sparkle">✦</span>
            </div>
        </div>

        <h1 class="provider-signup-title">Become a Provider</h1>
        <p class="provider-signup-subtitle">Join our marketplace and reach thousands of companies</p>

        <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="provider-signup-card">
            <DataAnnotationsValidator />
            <ValidationSummary class="provider-signup-validation" />

            <h2 class="provider-signup-card-title">Provider Application</h2>

            <div class="provider-signup-field">
                <label for="companyName">Company Name *</label>
                <InputText id="companyName" @bind-Value="_model.CompanyName" class="provider-signup-input" placeholder="Your Company Ltd." />
            </div>

            <div class="provider-signup-field">
                <label for="businessEmail">Business Email *</label>
                <InputText id="businessEmail" @bind-Value="_model.BusinessEmail" class="provider-signup-input" placeholder="contact@yourcompany.com" />
            </div>

            <div class="provider-signup-field">
                <label for="phoneNumber">Phone Number *</label>
                <InputText id="phoneNumber" @bind-Value="_model.PhoneNumber" class="provider-signup-input" placeholder="+1 (555) 123-4567" />
            </div>

            <div class="provider-signup-field">
                <label for="password">Password *</label>
                <InputText id="password" @bind-Value="_model.Password" type="password" class="provider-signup-input" placeholder="Create a secure password" />
            </div>

            <div class="provider-signup-field">
                <label for="companyDescription">Company Description *</label>
                <InputTextArea id="companyDescription" @bind-Value="_model.CompanyDescription" class="provider-signup-input provider-signup-textarea" placeholder="Tell us about your company and the experiences you offer..." />
            </div>

            <div class="provider-signup-field">
                <label for="website">Website</label>
                <InputText id="website" @bind-Value="_model.Website" class="provider-signup-input" placeholder="https://yourcompany.com" />
            </div>

            <div class="provider-signup-field">
                <label>Company Logo</label>
                <button type="button" class="provider-signup-upload">
                    <span class="provider-signup-upload-icon">⇪</span>
                    <span>Click to upload or drag and drop</span>
                    <small>PNG, JPG up to 5MB</small>
                </button>
            </div>

            <label class="provider-signup-checkbox">
                <InputCheckbox @bind-Value="_model.AcceptTerms" />
                <span>I agree to the Terms of Service and Privacy Policy, and confirm that all information provided is accurate.</span>
            </label>

            <button type="submit" class="provider-signup-submit">Submit Application</button>

            <p class="provider-signup-login">Already have an account? <a href="/login">Sign in here</a></p>
        </EditForm>

        <section class="provider-signup-next">
            <h2>What happens next?</h2>
            <ol>
                <li>Our team will review your application within 2-3 business days</li>
                <li>You'll receive an email notification once approved</li>
                <li>Start creating and publishing your packages immediately</li>
                <li>Receive bookings and grow your business with us</li>
            </ol>
        </section>
    </div>
</div>

@code {
    private readonly SignupModel _model = new();

    private void HandleSubmit()
    {
        Snackbar.Add("Application submitted. We will review it shortly.", Severity.Success);
        Navigation.NavigateTo("/login");
    }

    private sealed class SignupModel
    {
        [Required]
        public string CompanyName { get; set; } = string.Empty;

        [Required, EmailAddress]
        public string BusinessEmail { get; set; } = string.Empty;

        [Required]
        public string PhoneNumber { get; set; } = string.Empty;

        [Required, MinLength(6)]
        public string Password { get; set; } = string.Empty;

        [Required]
        public string CompanyDescription { get; set; } = string.Empty;

        public string Website { get; set; } = string.Empty;

        [Range(typeof(bool), "true", "true", ErrorMessage = "You must accept the terms.")]
        public bool AcceptTerms { get; set; }
    }
}

<style>
    .provider-signup-page {
        min-height: calc(100vh - 100px);
        padding: 130px 24px 90px;
        background: #f4f5f7;
    }

    .provider-signup-shell {
        max-width: 760px;
        margin: 0 auto;
        text-align: center;
    }

    .provider-signup-logo {
        display: inline-flex;
        flex-direction: column;
        margin-bottom: 28px;
        padding: 10px 18px;
        background: #ffffff;
    }

    .provider-signup-logo-top {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .provider-signup-line {
        width: 28px;
        height: 2px;
        background: #111827;
    }

    .provider-signup-company {
        color: #111827;
        font-size: 0.9rem;
        font-weight: 900;
        letter-spacing: 1px;
    }

    .provider-signup-logo-bottom {
        display: flex;
        align-items: flex-start;
        justify-content: center;
    }

    .provider-signup-outing {
        color: #111827;
        font-size: 3.2rem;
        font-weight: 950;
        letter-spacing: -2px;
        line-height: 1;
    }

    .provider-signup-sparkle {
        margin-top: 8px;
        margin-left: 4px;
        color: #111827;
        opacity: 0.8;
    }

    .provider-signup-title {
        margin: 0;
        color: #0f172a;
        font-size: clamp(2.6rem, 6vw, 3.8rem);
        font-weight: 900;
        letter-spacing: -1.8px;
    }

    .provider-signup-subtitle {
        margin: 14px 0 30px;
        color: #607089;
        font-size: 1.05rem;
    }

    .provider-signup-card {
        padding: 26px 24px 22px;
        border: 1px solid #d8c7b4;
        border-radius: 26px;
        background: #ffffff;
        text-align: left;
    }

    .provider-signup-card-title {
        margin: 0 0 24px;
        color: #6d4f32;
        font-size: 1.2rem;
        font-weight: 800;
    }

    .provider-signup-validation {
        margin-bottom: 14px;
        color: #b91c1c;
    }

    .provider-signup-field {
        margin-bottom: 22px;
    }

    .provider-signup-field label {
        display: block;
        margin-bottom: 10px;
        color: #6d4f32;
        font-size: 0.95rem;
        font-weight: 700;
    }

    .provider-signup-input {
        width: 100%;
        min-height: 54px;
        padding: 12px 14px;
        border: 1px solid #d7c1ae;
        border-radius: 18px;
        background: #ffffff;
        color: #9a6b45;
        font-family: inherit;
        font-size: 0.98rem;
    }

    .provider-signup-textarea {
        min-height: 120px;
        resize: vertical;
    }

    .provider-signup-upload {
        width: 100%;
        min-height: 150px;
        border: 2px dashed #c9d4e4;
        border-radius: 18px;
        background: #ffffff;
        color: #607089;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 8px;
        font-family: inherit;
        cursor: pointer;
    }

    .provider-signup-upload-icon {
        font-size: 1.8rem;
    }

    .provider-signup-upload small {
        color: #7a8aa4;
        font-size: 0.88rem;
    }

    .provider-signup-checkbox {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin: 8px 0 24px;
        color: #52627d;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .provider-signup-submit {
        width: 100%;
        min-height: 56px;
        border: none;
        border-radius: 16px;
        background: #1877f2;
        color: #ffffff;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 800;
        cursor: pointer;
    }

    .provider-signup-login {
        margin: 22px 0 0;
        text-align: center;
        color: #607089;
        font-size: 0.95rem;
    }

    .provider-signup-login a {
        color: #1877f2;
        font-weight: 800;
        text-decoration: none;
    }

    .provider-signup-next {
        margin-top: 32px;
        padding: 28px 24px;
        border: 1px solid #b9d3ff;
        border-radius: 20px;
        background: #eef5ff;
        text-align: left;
    }

    .provider-signup-next h2 {
        margin: 0 0 16px;
        color: #172033;
        font-size: 1.1rem;
        font-weight: 800;
    }

    .provider-signup-next ol {
        margin: 0;
        padding-left: 22px;
        color: #475569;
        line-height: 1.8;
    }

    @@media (max-width: 768px) {
        .provider-signup-page {
            padding-top: 110px;
        }

        .provider-signup-card,
        .provider-signup-next {
            padding-left: 18px;
            padding-right: 18px;
        }
    }
</style>
