@page "/"
@using MudBlazor

@using CompanyOuting.App.Client.Components.HomeSections

<HeroSection />

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pb-16 mt-32 px-12">
    <FeaturedExperiences />
    <StatsSection />
    <ExperienceTypes />
    <HowItWorksSection />
    <div style="background-color: #F0EFE9; width: 100vw; margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); padding: 80px 0;">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="px-12">
            <TestimonialsSection />
        </MudContainer>
    </div>
</MudContainer>

<ProviderBannerSection />
<TrustIconsSection />
<FinalCtaSection />

<style>
    :root {
        --color-site-dark: #111827;
        --color-site-grey: #64748b;
        --color-site-offwhite: #F8FAFC;
        --font-outfit: 'Outfit', sans-serif;
    }

    .font-black { font-weight: 900 !important; }
    .font-bold { font-weight: 700 !important; }
    .font-medium { font-weight: 500 !important; }
    .site-dark-text { color: var(--color-site-dark) !important; }
    .site-grey-text { color: var(--color-site-grey) !important; }
    .site-dark-bg { background-color: var(--color-site-dark) !important; }

    .hero-wrapper {
        min-height: 100vh;
        background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center bottom;
        background-attachment: fixed;
        width: 100%;
        color: white;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-gradient-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 350px;
        background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.7) 40%, rgba(255,255,255,1) 100%);
        pointer-events: none;
    }

    .hero-title {
        font-size: 5.8rem !important;
        line-height: 1.05;
        letter-spacing: -3px;
    }

    .hero-subtitle {
        max-width: 900px;
        font-size: 1.75rem !important;
        line-height: 1.5;
        opacity: 0.95;
    }

    .search-glass {
        background: rgba(45, 45, 45, 0.45) !important; /* blurry glassy grey */
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        width: 100%;
        max-width: 950px;
        margin-left: auto;
        margin-right: auto;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 4px !important;
    }

    .search-field-wrapper {
        display: flex;
        flex-direction: column;
    }

    .search-label {
        color: white;
    }

    .custom-hero-input {
        background-color: white !important;
        border-radius: 2px !important;
    }

    ::deep .custom-hero-input .mud-input {
        background-color: white !important;
        color: var(--color-site-dark) !important;
        border-radius: 2px !important;
    }

    ::deep .custom-hero-input .mud-input-slot {
        color: var(--color-site-dark) !important;
        font-weight: 500;
        padding: 10px 14px !important;
        font-size: 0.95rem;
    }

    ::deep .custom-hero-input .mud-input-outlined-border {
        border-color: transparent !important;
    }

    .search-btn {
        background-color: #0f172a !important;
        color: white !important;
        font-weight: 900 !important;
        letter-spacing: 1px;
        font-size: 0.9rem !important;
        border-radius: 2px !important;
    }

