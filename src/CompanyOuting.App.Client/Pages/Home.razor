    .type-title { font-size: 1.8rem !important; line-height: 1.25; letter-spacing: 0px; color: white !important; font-weight: 800 !important; }

    .type-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 100%;
        background: linear-gradient(to top, rgba(15, 23, 42, 0.95) 0%, rgba(15, 23, 42, 0) 100%);
        align-items: flex-start;
        justify-content: flex-end;
    }

