    }

    .border-t-1 { border-top: 1px solid rgba(0,0,0,0.08); }

    .browse-all-btn {
        background-color: var(--color-site-dark) !important;
        color: white !important;
        font-weight: 900 !important;
        font-size: 1.05rem !important;
        letter-spacing: 1px;
    }

