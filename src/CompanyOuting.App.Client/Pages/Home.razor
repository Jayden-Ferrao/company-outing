    .soft-box-icon {
        width: 72px;
        height: 72px;
        background-color: #F1F5F9;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .soft-box-icon:hover {
        background-color: #E2E8F0;
        transform: scale(1.05);
    }

    .trust-item-title { font-size: 1.15rem !important; }
    .trust-item-desc { font-size: 0.95rem !important; line-height: 1.6; padding: 0 10px; color: #475569 !important; }

