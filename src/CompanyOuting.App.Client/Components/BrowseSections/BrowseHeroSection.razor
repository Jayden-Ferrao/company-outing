@using MudBlazor

<div class="browse-hero">
    <div class="bhero-overlay"></div>
    <div class="bhero-content">
        <h6 class="bhero-badge">BROWSE EXPERIENCES</h6>
        <h1 class="bhero-title">Find the Perfect Experience<br/>for Your Team</h1>
        <p class="bhero-subtitle">Curated corporate outings tailored for 10-500+ participants.</p>
    </div>
</div>

<style>
    .browse-hero {
        position: relative;
        width: 100vw;
        height: 480px;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        background-color: #0f172a;
        background-image: url('https://images.unsplash.com/photo-1514867499690-34863abf08aa?q=80&w=2400&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
    }

    .bhero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(13, 31, 56, 0.75);
        z-index: 1;
    }

    .bhero-content {
        position: relative;
        z-index: 2;
        max-width: 900px;
        padding: 0 24px;
        margin-top: -20px;
    }

    .bhero-badge {
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 24px;
        opacity: 0.85;
    }

    .bhero-title {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -1px;
        margin-bottom: 24px;
    }

    .bhero-subtitle {
        font-size: 1.1rem;
        font-weight: 400;
        opacity: 0.9;
    }

    @@media (max-width: 960px) {
        .bhero-title {
            font-size: 2.5rem;
        }
    }
</style>
