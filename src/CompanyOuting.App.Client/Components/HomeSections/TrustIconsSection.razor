@using MudBlazor

@* Trust Icons *@
<div class="bg-white py-24 pb-32">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge">
        <MudGrid Justify="Justify.Center" Spacing="8">
            <MudItem xs="12" sm="6" md="3" Class="text-center px-4">
                <div class="soft-box-icon mb-6 mx-auto">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircleOutline" Class="site-dark-text" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.h6" Class="trust-item-title font-black mb-3">Verified Providers</MudText>
                <MudText Typo="Typo.body2" Class="trust-item-desc font-medium">Every provider is thoroughly vetted and verified before joining our marketplace.</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="text-center px-4">
                <div class="soft-box-icon mb-6 mx-auto">
                    <MudIcon Icon="@Icons.Material.Outlined.Shield" Class="site-dark-text" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.h6" Class="trust-item-title font-black mb-3">Safety Standards</MudText>
                <MudText Typo="Typo.body2" Class="trust-item-desc font-medium">All experiences meet strict safety and quality standards for corporate groups.</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="text-center px-4">
                <div class="soft-box-icon mb-6 mx-auto">
                    <MudIcon Icon="@Icons.Material.Outlined.WorkspacePremium" Class="site-dark-text" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.h6" Class="trust-item-title font-black mb-3">Corporate Insurance</MudText>
                <MudText Typo="Typo.body2" Class="trust-item-desc font-medium">Comprehensive insurance coverage for all bookings and group activities.</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="text-center px-4">
                <div class="soft-box-icon mb-6 mx-auto">
                    <MudIcon Icon="@Icons.Material.Outlined.HeadsetMic" Class="site-dark-text" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.h6" Class="trust-item-title font-black mb-3">Dedicated Support</MudText>
                <MudText Typo="Typo.body2" Class="trust-item-desc font-medium">24/7 dedicated support team for planning and during your experience.</MudText>
            </MudItem>
        </MudGrid>
    </MudContainer>
</div>
