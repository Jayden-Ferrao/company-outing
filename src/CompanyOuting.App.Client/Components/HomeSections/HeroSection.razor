@using MudBlazor

@* Hero Section - Full width, premium background *@
<div class="hero-wrapper">
    <div class="hero-content w-100 d-flex flex-column align-center justify-center mx-auto" style="z-index: 10;">
        <MudText Typo="Typo.h2" Align="Align.Center" Class="hero-title font-black">
            Corporate Team Experiences.<br />Curated. Scalable. Bookable.
        </MudText>
        <MudText Typo="Typo.h6" Align="Align.Center" Class="hero-subtitle mt-8 font-medium">
            Discover and book verified team outings for 10-500+ employees across Norway and beyond.
        </MudText>

        <MudPaper Class="search-glass pa-8 mt-12" Elevation="0">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6" md="3">
                    <div class="search-field-wrapper">
                        <div class="search-label d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Small" Style="color: white;" />
                            <MudText Typo="Typo.caption" Class="font-black text-white" Style="letter-spacing: 1px;">REGION</MudText>
                        </div>
                        <MudSelect T="string" Placeholder="Select Region" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Class="custom-hero-input">
                            <MudSelectItem Value="@("Oslo")">Oslo</MudSelectItem>
                            <MudSelectItem Value="@("Bergen")">Bergen</MudSelectItem>
                            <MudSelectItem Value="@("Stavanger")">Stavanger</MudSelectItem>
                        </MudSelect>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <div class="search-field-wrapper">
                        <div class="search-label d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Size="Size.Small" Style="color: white;" />
                            <MudText Typo="Typo.caption" Class="font-black text-white" Style="letter-spacing: 1px;">LOCATION</MudText>
                        </div>
                        <MudTextField T="string" Placeholder="City or venue" Variant="Variant.Outlined" Margin="Margin.Dense" Class="custom-hero-input" />
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <div class="search-field-wrapper">
                        <div class="search-label d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@Icons.Material.Outlined.People" Size="Size.Small" Style="color: white;" />
                            <MudText Typo="Typo.caption" Class="font-black text-white" Style="letter-spacing: 1px;">GROUP SIZE</MudText>
                        </div>
                        <MudNumericField T="int" Placeholder="Number of people" Variant="Variant.Outlined" Margin="Margin.Dense" HideSpinButtons="true" Class="custom-hero-input" />
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <div class="search-field-wrapper">
                        <div class="search-label d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@Icons.Material.Outlined.CalendarMonth" Size="Size.Small" Style="color: white;" />
                            <MudText Typo="Typo.caption" Class="font-black text-white" Style="letter-spacing: 1px;">DATE</MudText>
                        </div>
                        <MudDatePicker Placeholder="mm / dd / yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" Class="custom-hero-input" />
                    </div>
                </MudItem>
                <MudItem xs="12" Class="pt-6">
                    <MudButton Variant="Variant.Filled" FullWidth="true" Class="search-btn py-3" StartIcon="@Icons.Material.Outlined.Search">
                        SEARCH EXPERIENCES
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </div>
    <div class="hero-gradient-overlay"></div>
</div>
