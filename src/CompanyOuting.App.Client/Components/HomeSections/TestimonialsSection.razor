@using MudBlazor

@* Testimonials Section *@
<div class="testimonials-section-wrapper">
    <MudGrid Spacing="6">
        @for (var i = 0; i < _testimonials.Count; i++)
        {
            var test = _testimonials[i];
            <MudItem xs="12" md="4">
                <div class="t-card">
                    <div class="t-media-wrap">
                        @if (!string.IsNullOrWhiteSpace(test.Avatar))
                        {
                            <img src="@test.Avatar" alt="@test.Name" class="t-avatar" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Assignment" Class="t-icon" />
                        }
                    </div>
                    <p class="t-quote">"@test.Quote"</p>
                    <div class="t-author">
                        <span class="t-name">@test.Name</span>
                        <span class="t-role">@test.Role</span>
                    </div>
                </div>
            </MudItem>
        }
    </MudGrid>
</div>

<style>
    .testimonials-section-wrapper {
        padding-top: 48px;
        padding-bottom: 48px;
    }

    .t-card {
        background-color: #ffffff;
        border-radius: 30px;
        padding: 34px 34px 30px;
        display: flex;
        flex-direction: column;
        min-height: 520px;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.08), 0 2px 6px rgba(15, 23, 42, 0.05);
    }

    .t-media-wrap {
        display: flex;
        align-items: center;
        min-height: 52px;
        margin-bottom: 34px;
    }

    .t-avatar {
        width: 36px;
        height: 52px;
        object-fit: cover;
        border-radius: 2px;
    }

    .t-icon {
        font-size: 3.4rem !important;
        color: #97a8c2 !important;
    }

    .t-quote {
        font-size: 1.12rem;
        line-height: 1.7;
        color: #344767;
        font-weight: 500;
        flex-grow: 1;
        margin: 0 0 42px;
    }

    .t-author {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-top: auto;
    }

    .t-name {
        font-size: 1.08rem;
        font-weight: 800;
        color: #0f172a;
    }

    .t-role {
        font-size: 0.92rem;
        color: #7183a0;
        font-weight: 500;
    }

    @@media (max-width: 960px) {
        .t-card {
            min-height: 420px;
        }
    }
</style>

@code {
    private List<Testimonial> _testimonials = new()
    {
        new Testimonial { Quote = "Company Outing transformed how we plan team events. The quality of venues and seamless booking process saved us weeks of work.", Name = "Sarah Jensen", Role = "Head of People, TechCorp AS", Avatar = "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=120&auto=format&fit=crop" },
        new Testimonial { Quote = "We hosted 300 employees at a fjord retreat. Every detail was perfect. This platform is a game-changer for corporate events.", Name = "Marcus Berg", Role = "CEO, Nordic Finance Group" },
        new Testimonial { Quote = "The verified providers and transparent pricing gave us confidence. Our team still talks about the experience months later.", Name = "Emma Larsen", Role = "Operations Director, Stavanger Energy" }
    };

    public class Testimonial {
        public string Quote { get; set; } = "";
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public string Avatar { get; set; } = "";
    }
}
