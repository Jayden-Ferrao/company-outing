@using MudBlazor

@* Become a Provider Section *@
<div class="provider-banner-wrapper py-32">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="text-center px-12">
        <MudText Typo="Typo.h2" Class="provider-title font-black text-white">Are You a Corporate Experience Provider?</MudText>
        <MudText Typo="Typo.h5" Class="provider-subtitle mt-8 mb-12 mx-auto text-white opacity-90 font-medium">
            Join our marketplace and reach thousands of companies planning their next team outing.
        </MudText>
        <div class="d-flex justify-center gap-8">
            <MudButton Variant="Variant.Filled" Href="/login" Class="provider-btn-primary py-5 px-12 rounded-lg font-black b-shadow" EndIcon="@Icons.Material.Filled.ArrowForward">Become a Provider</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Class="provider-btn-outline py-5 px-12 rounded-lg font-black">Learn More</MudButton>
        </div>
    </MudContainer>
</div>
