@using MudBlazor
@rendermode InteractiveServer
@implements IDisposable

@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject UserSessionService Session

<MudAppBar Elevation="0" Fixed="true" Class="px-12 site-header" Style="background-color: white !important; border-bottom: 1px solid rgba(0,0,0,0.06);">
    @* Logo Section *@
    <MudLink Href="/" Underline="Underline.None" Class="d-flex align-center mr-16">
        <div class="logo-wrapper-custom">
            <div class="logo-top-line d-flex align-center justify-center gap-2">
                <span class="l-line"></span>
                <span class="l-text-tiny">COMPANY</span>
                <span class="l-line"></span>
            </div>
            <div class="logo-bottom-line d-flex align-center justify-center">
                <span class="l-text-huge">OUTING</span>
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="l-sparkle" />
            </div>
        </div>
    </MudLink>
    
    <MudSpacer />

    @* Navigation Links *@
    <div class="d-none d-lg-flex gap-10 align-center nav-links-wrap">
        <MudLink Href="/about" Class="nav-item-link">ABOUT</MudLink>
        <MudLink Href="/marketplace" Class="nav-item-link">BROWSE EXPERIENCES</MudLink>
    </div>

    @* Action Buttons *@
    <div class="d-flex gap-4 align-center">
        @if (IsProviderContext)
        {
            <MudButton Variant="Variant.Outlined" Class="header-btn-rect px-8 py-3" Href="/provider/create">CREATE EXPERIENCE</MudButton>
            <MudButton Variant="Variant.Outlined" Class="header-btn-pill px-8 py-3" OnClick="SignOut">SIGN OUT</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Outlined" Class="header-btn-pill px-8 py-3" Href="/login">PROVIDER LOGIN</MudButton>
        }
    </div>
</MudAppBar>

@code {
    private bool _sessionLoaded;

    protected override void OnInitialized()
    {
        Session.Changed += HandleSessionChanged;
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _sessionLoaded)
        {
            return;
        }

        await Session.EnsureLoadedAsync(JsRuntime);
        _sessionLoaded = true;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private bool IsProviderContext =>
        Session.IsProvider || Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("provider/", StringComparison.OrdinalIgnoreCase);

    private async Task SignOut()
    {
        await Session.SignOutAsync(JsRuntime);
        Navigation.NavigateTo("/marketplace");
    }

    public void Dispose()
    {
        Session.Changed -= HandleSessionChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}

<style>
    .site-header {
        height: 100px !important;
        color: #111827 !important;
    }

    .logo-wrapper-custom {
        display: flex;
        flex-direction: column;
        line-height: 1;
        transform: translateY(2px);
    }

    .logo-top-line {
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 2px;
        color: #111827;
        opacity: 0.9;
    }

    .l-line {
        height: 2px;
        width: 18px;
        background-color: #111827;
        opacity: 0.5;
    }

    .l-text-huge {
        font-size: 2.4rem;
        font-weight: 950;
        color: #111827;
        letter-spacing: -1.5px;
    }

    .l-sparkle {
        color: #111827 !important;
        opacity: 0.8;
        margin-left: 2px;
        margin-top: 6px;
        font-size: 1.2rem !important;
    }

    .nav-item-link {
        font-size: 0.9rem !important;
        font-weight: 850 !important;
        color: #111827 !important;
        letter-spacing: 0.5px !important;
        text-decoration: none !important;
    }

    .nav-links-wrap {
        margin-right: 36px;
    }

    .nav-item-link:hover {
        opacity: 0.7;
        color: #111827 !important;
    }

    .header-btn-rect {
        border-radius: 4px !important;
        border: 2px solid #111827 !important;
        color: #111827 !important;
        font-weight: 900 !important;
        font-size: 0.85rem !important;
        text-transform: none !important;
    }

    .header-btn-pill {
        border-radius: 50px !important;
        border: 2px solid #111827 !important;
        color: #111827 !important;
        font-weight: 900 !important;
        font-size: 0.85rem !important;
        text-transform: none !important;
    }

    .header-btn-rect:hover, .header-btn-pill:hover {
        background-color: #111827 !important;
        color: white !important;
    }
</style>
