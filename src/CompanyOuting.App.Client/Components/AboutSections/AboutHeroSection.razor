@using MudBlazor

<div class="about-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h6 class="about-badge">ABOUT US</h6>
        <h1 class="hero-title">Company Outings.<br/>Reimagined.</h1>
        <p class="hero-subtitle">Extraordinary group experiences crafted with intention.</p>
    </div>
</div>

<style>
    .about-hero {
        position: relative;
        width: 100vw;
        height: 60vh;
        min-height: 600px;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        background-color: #0f172a;
        background-image: url('https://images.unsplash.com/photo-1548266652-99cf27701ced?q=80&w=2400&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.85) 100%);
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 900px;
        padding: 0 24px;
    }

    .about-badge {
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 20px;
        opacity: 0.8;
    }

    .hero-title {
        font-size: 4rem;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -1.5px;
        margin-bottom: 24px;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        font-weight: 400;
        opacity: 1;
    }

    @@media (max-width: 960px) {
        .hero-title {
            font-size: 3rem;
        }
    }
</style>
