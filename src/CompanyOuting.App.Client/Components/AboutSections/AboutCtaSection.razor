@using MudBlazor

<div class="cta-banner">
    <div class="cta-overlay"></div>
    <div class="cta-content">
        <h2 class="cta-title">Let's Make Magic Happen</h2>
        <p class="cta-subtitle">
            Every Company Outing is crafted in collaboration with trusted experts and partners. Choose your favorite experience and we'll deliver a concept that fits your company's needs, goals, and vibe.
        </p>

        <div class="d-flex justify-center gap-4 flex-wrap mt-8">
            <MudButton Variant="Variant.Filled" Size="Size.Large" Class="cta-btn-primary px-8 py-3">
                EXPLORE EXPERIENCES <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="ms-2"/>
            </MudButton>
            <MudButton Variant="Variant.Outlined" Size="Size.Large" Class="cta-btn-secondary px-8 py-3">
                <MudIcon Icon="@Icons.Material.Outlined.Email" Size="Size.Small" Class="me-2"/> GET IN TOUCH
            </MudButton>
        </div>

        <div class="cta-bottom-stats mt-12 d-flex justify-center flex-wrap gap-8">
            <span class="cta-stat-item">&bull;&nbsp; 500+ EXPERIENCES</span>
            <span class="cta-stat-item">&bull;&nbsp; 35+ COUNTRIES</span>
            <span class="cta-stat-item">&bull;&nbsp; 40+ YEARS EXPERIENCE</span>
        </div>
    </div>
</div>

<style>
    .cta-banner {
        position: relative;
        width: 100vw;
        min-height: 500px;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        background-color: #0f172a;
        background-image: url('https://images.unsplash.com/photo-1543269865-cbf427effbad?q=80&w=2400&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
        padding: 80px 24px;
    }

    .cta-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.7);
        z-index: 1;
    }

    .cta-content {
        position: relative;
        z-index: 2;
        max-width: 800px;
        width: 100%;
    }

    .cta-title {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 24px;
    }

    .cta-subtitle {
        font-size: 1.15rem;
        line-height: 1.6;
        color: rgba(255,255,255,0.9);
        font-weight: 400;
        margin: 0 auto;
        max-width: 650px;
    }

    .cta-btn-primary {
        background-color: #ffffff !important;
        color: #0f172a !important;
        font-weight: 800 !important;
        font-size: 0.9rem !important;
        letter-spacing: 1px !important;
        border-radius: 4px !important;
    }

    .cta-btn-secondary {
        border: 1px solid rgba(255,255,255,0.8) !important;
        color: #ffffff !important;
        font-weight: 800 !important;
        font-size: 0.9rem !important;
        letter-spacing: 1px !important;
        border-radius: 4px !important;
    }

    .cta-btn-secondary:hover {
        background-color: rgba(255,255,255,0.1) !important;
    }

    .cta-bottom-stats {
        opacity: 0.8;
    }

    .cta-stat-item {
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        color: #e2e8f0;
    }
</style>
